{
  "name": "beasties-webpack-plugin",
  "version": "0.4.3",
  "description": "Webpack plugin to inline critical CSS and lazy-load the rest.",
  "author": "The Chromium Authors",
  "contributors": [
    {
      "name": "Jason Miller",
      "email": "developit@google.com"
    },
    {
      "name": "Janicklas Ralph",
      "email": "janicklas@google.com"
    },
    {
      "name": "Daniel Roe",
      "email": "daniel@roe.dev",
      "url": "https://roe.dev"
    }
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/danielroe/beasties",
    "directory": "packages/beasties-webpack-plugin"
  },
  "keywords": [
    "critical css",
    "inline css",
    "critical",
    "beasties",
    "webpack plugin",
    "performance"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.cts",
  "files": [
    "dist",
    "src"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.0.0"
  },
  "scripts": {
    "build": "tsdown",
    "docs": "documentation readme src -q --no-markdown-toc -a public -s Usage --sort-order alpha",
    "prepack": "npm run -s build"
  },
  "peerDependencies": {
    "html-webpack-plugin": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "html-webpack-plugin": {
      "optional": true
    }
  },
  "dependencies": {
    "beasties": "workspace:*",
    "minimatch": "^10.0.1"
  },
  "devDependencies": {
    "@types/jsdom": "28.0.3",
    "css-loader": "7.1.4",
    "documentation": "14.0.3",
    "file-loader": "6.2.0",
    "html-webpack-plugin": "5.6.7",
    "mini-css-extract-plugin": "2.10.2",
    "tsdown": "0.22.7",
    "webpack": "5.108.4"
  }
}
